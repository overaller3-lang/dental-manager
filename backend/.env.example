# Esempio di configurazione per l'avvio LOCALE del backend (senza Docker).
# Copiare in .env e adattare ai propri valori.
#
# Per l'avvio con docker compose, queste variabili sono già definite
# nel docker-compose.yml e questo file non viene letto.

# Connessione PostgreSQL (formato: postgresql://user:password@host:port/dbname)
DATABASE_URL=postgresql://dental_user:dental_pass@localhost:5432/dental_db

# Chiave per firmare i JSON Web Token. Generare con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia_questa_chiave_con_almeno_32_caratteri_casuali

# Durata del token JWT in minuti. Default 480 (8 ore = un turno lavorativo).
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Modalità verbosa per lo sviluppo
DEBUG=False
